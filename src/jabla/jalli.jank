(ns jabla.jalli
  (:require [clojure.string :as str]
            [jabla.schema :as schema]))

;; ============================================================================
;; jalli -- a tiny malli-flavored, schema-as-DATA validation layer for jabla,
;; built the only way it can be on jank-alpha: multimethods over plain data.
;;
;; WHY this shape (not malli/spec/plumatic-schema): none of those load on jank --
;; they are protocol/record-based, and jank-alpha has no defprotocol/defrecord/
;; deftype/reify (it DOES have defmulti + maps/vectors). It also can't even lex
;; malli's source (a `-r...` symbol lexer bug). Full evidence: docs/typing-spike.md.
;; So jalli keeps malli's two best ideas -- schemas are data, errors are data --
;; and drops its implementation (protocols) for defmulti dispatch on a tag keyword.
;;
;; A SCHEMA is data:
;;   - a keyword            a leaf, e.g. :tensor
;;   - a [tag & children]   a composite, e.g. [:and :tensor ...], or [:matmul]
;; The leaf checks reuse jabla.schema's predicates (tensor?, matmul-compatible?) --
;; the dependent-shape checks are hand-written code in every world (malli can't
;; express them either), so jalli just gives them a declarative, composable face.
;;
;; The public surface mirrors malli on purpose (validate / explain / humanize /
;; check), so the muscle memory transfers and a future swap to real malli -- once
;; jank grows protocols + the lexer fix, OR malli ships :jank reader-conditionals --
;; is mechanical. See docs/jalli-design.md for the grammar + migration path.
;; ============================================================================

;; --- Schema accessors -------------------------------------------------------

(defn- schema-tag
  "The dispatch keyword for a schema: the keyword itself, or a vector's head."
  [s]
  (if (vector? s) (first s) s))

(defn- schema-children
  "The child schemas of a composite (empty for a bare-keyword leaf)."
  [s]
  (if (vector? s) (rest s) ()))

;; --- The engine: -problems (schema -> value -> seq of problem strings) ------
;; This is the one extensible point. validate / explain / humanize / check are all
;; thin wrappers over it. To add a schema type, add a -problems defmethod -- no
;; protocol to implement, just a method keyed on the tag (jank has defmulti).
;; An empty seq means valid; a non-empty seq is the human-readable reasons.

(defmulti -problems
  "Return a seq of problem strings for `value` under `schema` ([] = valid)."
  (fn [schema _value] (schema-tag schema)))

(defmethod -problems :tensor [_ value]
  ;; Leaf: structurally a well-formed tensor map. Reuse schema/explain-tensor,
  ;; which already returns nil (valid) or a vector of problems.
  (or (schema/explain-tensor value) []))

(defmethod -problems :and [schema value]
  ;; Conjunction: value must satisfy every child schema. Collect all problems
  ;; (not just the first) so explain is complete.
  (reduce (fn [acc child] (into acc (-problems child value)))
          []
          (schema-children schema)))

(defn- pair-problems
  "Problems for a binary-op argument tuple: `value` must be a 2-tuple [a b] of
  well-formed tensors that satisfy `relation?` (a shape relation like matmul-compatible?
  or same-shape?). `desc` names the relation for the error message. This is the shape of
  every dependent-shape op boundary -- the 'value' validated is the op's argument list,
  which is how a relation between two args fits the validate-one-value contract."
  [value relation? desc]
  (cond
    (not (and (vector? value) (= 2 (count value))))
    [(str "expected a 2-tuple [a b], got " value)]

    (seq (or (schema/explain-tensor (first value)) []))
    (schema/explain-tensor (first value))

    (seq (or (schema/explain-tensor (second value)) []))
    (schema/explain-tensor (second value))

    (not (relation? (first value) (second value)))
    [(str desc ": " (:shape (first value)) " vs " (:shape (second value)))]

    :else []))

(defmethod -problems :matmul [_ value]
  ;; Dependent-shape leaf for the matmul op boundary: [a b] both tensors AND inner dims
  ;; match. The check that otherwise lets a bad shape segfault the cblas kernel.
  (pair-problems value schema/matmul-compatible?
                 "matmul shapes incompatible (inner dims must match)"))

(defmethod -problems :same-shape [_ value]
  ;; Dependent-shape leaf for the elementwise op boundary (add / mul): [a b] both
  ;; tensors AND equal shapes. (Relaxes to broadcastable? once broadcasting lands.)
  (pair-problems value schema/same-shape? "shapes must be equal"))

(defmethod -problems :tuple [schema value]
  ;; Positional: `value` is a vector whose i-th element matches the i-th child schema.
  ;; The general arg-vector schema -- e.g. a unary op's args are [:tuple :tensor], a
  ;; binary op's are [:tuple :tensor :tensor] (or a relation like :matmul over the pair).
  (let [schemas (schema-children schema)]
    (if-not (and (vector? value) (= (count value) (count schemas)))
      [(str ":tuple expects a " (count schemas) "-vector, got " value)]
      (reduce (fn [acc [s v]] (into acc (-problems s v)))
              []
              (map vector schemas value)))))

(defmethod -problems :default [schema _value]
  (throw (ex-info (str "jalli: unknown schema tag " (schema-tag schema))
                  {:schema schema})))

;; --- Public surface (mirrors malli) -----------------------------------------

(defn validate
  "True iff `value` satisfies `schema`."
  [schema value]
  (not (seq (-problems schema value))))

(defn explain
  "nil if valid, else a vector of problem strings -- data describing what failed.
  Pure; safe to call in a REPL on a suspect value."
  [schema value]
  ;; NB: `into []` not `vec` -- jank-alpha's `vec` throws on an already-vector input
  ;; (see private/jank-alpha-findings.md, bug 3); `into []` is idempotent.
  (let [ps (-problems schema value)]
    (if (seq ps) (into [] ps) nil)))

(defn humanize
  "A single human-readable string for an `explain` result (nil -> nil)."
  [problems]
  (when (seq problems)
    (str/join "; " problems)))

(defn check
  "Return `value` if valid, else throw ex-info naming the problems. Use at an op
  boundary for a clear failure instead of a downstream segfault. Example:
    (defn matmul [a b] (jalli/check [:matmul] [a b]) ...)"
  [schema value]
  (let [ps (-problems schema value)]
    (if (seq ps)
      (throw (ex-info (str "jalli: " (humanize ps)) {:schema schema :problems (into [] ps)}))
      value)))

;; --- defn-checked: declare an op's input/output contract on the defn ----------
;; A >defn-style wrapper (cf. plumatic schema's `s/defn :-`, guardrails `>defn`): the
;; contract rides on the definition instead of an inline (check ...). `contract` is a
;; literal map, both keys optional:
;;   :args  a schema for the VECTOR of argument values -- a relation over the args like
;;          [:matmul] / [:same-shape], or [:tuple s ...] positionally (e.g. a unary op's
;;          args are [:tuple :tensor]).
;;   :ret   a schema for the return value (e.g. :tensor).
;; Args are validated before the body, the return after -- both via `check` (throws on
;; violation). An optional docstring may precede the contract, like defn.
;;
;; Deliberately minimal -- jabla's ops are fixed-arity, plain-symbol argvecs: single
;; arity, no destructuring / & rest / multi-arity. (clj-kondo lints it via :lint-as
;; clojure.core/defn -- the contract map sits in defn's attr-map slot, so arglist + body
;; are analyzed normally; see .clj-kondo/config.edn.)
(defmacro defn-checked
  [nm & more]
  (let [has-doc  (string? (first more))
        doc      (when has-doc (first more))
        more2    (if has-doc (rest more) more)
        contract (first more2)
        argv     (second more2)
        body     (drop 2 more2)
        args-schema (:args contract)
        ret-schema  (:ret contract)
        rsym        (gensym "ret")]
    `(defn ~nm ~@(when doc [doc]) ~argv
       ~@(when args-schema [`(check ~args-schema [~@argv])])
       (let [~rsym (do ~@body)]
         ~@(when ret-schema [`(check ~ret-schema ~rsym)])
         ~rsym))))
