(ns jabla.tensor
  (:include "jabla.hpp"))

(def DEFAULT_DTYPE :f32)

;; ============================================================================
;; Tensors with autograd, on native BLAS. Roadmap step 3: lift jabla.autograd
;; from scalars to arrays. Validators: one attention block matches PyTorch
;; element-wise; end-to-end, nanoGPT's loss-per-step curve on TinyShakespeare
;; (log to experiments/). References: reference/llm.c, reference/nanoGPT.
;;
;; The op forwards (matmul + add) run on the native kernels in jabla.hpp; the
;; eager explicit-graph engine (backward! over a node-on-tensor DAG) is next.
;; ============================================================================

;; --- Representation (decided) -----------------------------------------------
;; A tensor is a jank map. It carries both its data handle and its provenance --
;; this IS the autograd graph (see below):
;;   {:shape [d0 d1 ...] :dtype :f32 :id <handle> :op <kw> :inputs [t ...]}.
;;   - :shape  -- dimension sizes (row-major), a plain jank vector.
;;   - :dtype  -- :f32 in the buffer (matches sgemm and the GPU end-state); the
;;     jank API speaks doubles and narrows at the boundary. Carrying :dtype keeps
;;     fp16/bf16 a storage change later, not a rewrite.
;;   - :id     -- index into a native float32 buffer C++ owns (jabla.hpp's
;;     registry); kernels read/write these by id. Bulk data never lives in jank:
;;     it holds only the handle and marshals at the edges (->tensor / ->vectors).
;;   - :op     -- the op keyword that produced this tensor (:leaf for inputs,
;;     :matmul / :add / ... for op results). Backward dispatches the vjp on this.
;;   - :inputs -- the input tensors this was computed from ([] for a leaf). These
;;     references ARE the graph edges.

;; --- Autograd: node-on-tensor DAG (decided 2026-06-08) ----------------------
;; The graph is the immutable tensor DAG itself: each op result carries its :op +
;; :inputs, so the tensor you hold IS its graph node (PyTorch grad_fn / tinygrad
;; _ctx). No global tape, no threaded tape -- the graph is already a value, and the
;; same DAG becomes the lazy graph in a later stage. backward! walks it reverse-topo
;; from a root, dispatches each node's vjp by :op (vjp-as-data, a rule registry),
;; and accumulates grads per buffer id -- SUMMING when an id is used more than once
;; (weight-tying correctness; see engine-design.md #5).
;;   Key insight: matmul's vjp is itself two matmuls of the upstream gradient with
;;   the inputs (work out which sides/transposes) -- so backward *also* routes
;;   through the matmul kernel (cpp/jabla.matmul). add's vjp passes the grad through.
;; Full decision + the staged eager -> lazy -> fused roadmap: docs/engine-design.md.




;; --- Public surface ---------------------------------------------------------
;; Construction + readback + matmul + add forwards are done; recording provenance
;; on the forwards + backward! / grad over the DAG are next (stage 1).

(defn- shape-of
  "Infer a row-major shape from nested vectors: count siblings at each depth,
  following the first element down until the leaves stop being vectors. Assumes
  rectangular nesting."
  [v]
  (->> v (iterate first) (take-while vector?) (mapv count)))

(defn ->tensor
  "Construct a tensor from nested jank vectors (row-major). Infers :shape, then
  flattens row-major and hands the elements to the C++ registry, which returns
  the buffer handle we store as :id. (vec forces the flatten -- jank marshals a
  persistent vector to std::vector, but not a lazy seq.)"
  [v]
  (let [shape (shape-of v)
        t-id  (cpp/jabla.createTensor (-> v flatten vec))]
    {:shape  shape
     :dtype  DEFAULT_DTYPE
     :id     t-id
     :op     :leaf      ; a graph leaf -- backward accumulates a grad here, stops
     :inputs []}))

(defn get-shape
  "Vector of dimension sizes."
  [t]
  (:shape t))

(defn get-dtype
  "Element type keyword (:f32 to start)."
  [t]
  (:dtype t))

(defn reshape
  "Nest a row-major element sequence into vectors of `shape`.

  Tracks clojure.core.matrix/reshape: flattens `m` first (its current shape is
  irrelevant), then refills row-major -- truncating if there are too many
  elements, zero-padding if too few.

  Built outside-in: `build` peels the outermost dim off `dims`, emits one child
  per index, and recurses on the rest; the base case (no dims left) is a single
  element. `stride` is the row-major stride of the current axis -- how many flat
  elements one step along it spans. Eager vector ops only: jank's lazy
  partition/rseq are unreliable (docs/jank-notes.md)."
  [m shape]
  (let [flat (vec (flatten m))
        n    (count flat)]
    (letfn [(build [offset dims]
              (if (empty? dims)
                ;; one element; zero-pad once we run off the end of `flat`
                (if (< offset n) (nth flat offset) 0.0)
                (let [stride (reduce * 1 (rest dims))]
                  (mapv (fn [i] (build (+ offset (* i stride)) (rest dims)))
                        (range (first dims))))))]
      (build 0 shape))))

(defn ->vectors
  "Read a tensor back into nested jank vectors (for tests / debugging): pull the
  flat buffer from C++ by :id, then reshape it to the tensor's shape. This is
  core.matrix's to-nested-vectors -- the inverse of ->tensor."
  [t]
  (let [raw-v (-> t :id cpp/jabla.getTensor)]
    (reshape raw-v (get-shape t))))

;; --- Op model: every op is forward + vjp, recorded on the DAG ---------------
;; An op here is the tensor analogue of a scalar autograd op (jabla.autograd): a
;; forward computation that ALSO records its node on the graph -- it tags the
;; result with :op + :inputs, so the returned tensor is its own graph node and
;; backward! can walk + dispatch the vjp (vector-Jacobian product) by :op. Forward
;; + recorded node, always both; ops differ only in what the forward computes:
;;   matmul         (m x k).(k x n) matrix product -- contraction, BLAS kernel
;;   add            a + b elementwise              -- vjp passes grad through
;;   mul            a * b ELEMENTWISE (Hadamard)   -- NOT matmul; dA=dY*b, dB=dY*a
;;   relu/gelu      activation, elementwise        -- vjp: * activation derivative
;;   softmax        row-wise exp/sum               -- reduction
;;   layernorm      per-row normalize + affine     -- reduction
;;   embedding      gather rows by index           -- vjp: scatter-add to used rows
;;   cross-entropy  scalar loss                    -- vjp: (softmax - onehot)/N
;; matmul (matrix product) != mul (elementwise) -- both exist, distinct ops. The
;; forward is a BLAS call only for the contraction ops; add/relu are plain
;; elementwise loops. The common thread is the tape, not BLAS.
;;
;; The forwards now also record their graph node (:op + :inputs); the vjp rules
;; that consume those nodes live in the vjp-rules registry below (TODO(you)).

(defn matmul
  "a (m x k) . b (k x n) -> (m x n). Forward via the native cblas_sgemm kernel
  (cpp/jabla.matmul), tagged as a :matmul node over [t1 t2]. vjp (in vjp-rules) is
  two matmuls of the upstream gradient with a and b -- work out the sides/transposes
  -- routed back through cpp/jabla.matmul."
  [t1 t2]
  (let [[m k] (get-shape t1)
        [_ n] (get-shape t2)
        t3-id (cpp/jabla.matmul (:id t1) (:id t2) m n k)]
    {:shape [m n] :dtype (get-dtype t1) :id t3-id :op :matmul :inputs [t1 t2]}))

(defn add
  "Elementwise a + b (same shape for now; broadcasting later). Forward via the
  native cpp/jabla.add kernel; the result carries a's shape unchanged (add is
  rank-agnostic, unlike matmul), tagged as an :add node over [t1 t2]. vjp (in
  vjp-rules) passes the gradient straight through to both inputs (with broadcasting,
  later, sum it back down to each input's shape)."
  [t1 t2]
  (let [t3-id (cpp/jabla.add (:id t1) (:id t2))]
    {:shape (get-shape t1) :dtype (get-dtype t1) :id t3-id :op :add :inputs [t1 t2]}))

;; TODO(you): the GPT op set, each = forward (records its node) + a vjp rule,
;; validated vs PyTorch: mul, relu/gelu, softmax, layernorm, embedding, cross-entropy.

;; --- Backward (stage 1 -- TODO(you)) -----------------------------------------
;; The engine is three pieces: a vjp-rules registry (op -> backward rule),
;; backward! (walk the DAG, dispatch, accumulate), and grad (read a result out).
;; Scaffolded as contracts; the traversal + the calculus are yours to implement.

(def vjp-rules
  "Registry mapping an :op keyword to its vjp (vector-Jacobian product) rule --
  vjp-as-data, the inspectable form (not closures). Suggested rule shape:

    (fn [node grad-out] -> [grad-for-input-0 grad-for-input-1 ...])

  where `node` is the op-result tensor (carries :inputs, :shape, :id) and
  `grad-out` is the upstream gradient tensor; the rule returns one gradient tensor
  per entry in (:inputs node), to be accumulated into those inputs. Adjust the
  signature to taste -- it's the seam, not a mandate.

  TODO(you): populate
    :add    -- pass grad-out straight through to both inputs ([grad-out grad-out]).
    :matmul -- two matmuls: dA = grad-out . Bt, dB = At . grad-out (sort out the
               transposes; route through cpp/jabla.matmul, add a transpose helper)."
  {:add (fn [_ grad-out] [grad-out grad-out])
   })

(defn seed-gradients
  [_root]
  )

(defn backward!
  "Reverse-mode backward over the node-on-tensor DAG rooted at `root`.
  Contract (stage 1):
    - seed the root's gradient (ones of root's shape -- this makes grad correspond
      to d(sum root)/d(input), which the finite-diff grad-check checks against);
    - visit nodes in reverse-topological order from root (a non-:leaf node's edges
      are its :inputs);
    - at each node, look up (vjp-rules (:op node)), call it with the node's
      accumulated grad, and ACCUMULATE the returned gradients into its inputs --
      SUMMING when an input id is reached more than once (weight-tying correctness);
    - return the accumulated gradients (keyed so `grad` can find them by tensor).
  No global state -- the returned grads ARE the result (collapse to a stored form
  later if you prefer). TODO(you)."
  [_root]
  (throw (ex-info "not implemented" {})))

(defn grad
  "Look up the accumulated gradient tensor for `t` in the grads returned by
  backward! (e.g. by (:id t)). TODO(you)."
  [_grads _t]
  (throw (ex-info "not implemented" {})))

;; Stage roadmap (eager backward -> arena lifetime -> lazy realize -> fusion ->
;; backend dispatch) lives in docs/engine-design.md. This file is stage 1.
