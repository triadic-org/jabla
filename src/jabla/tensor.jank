(ns jabla.tensor
  (:include "tensor.hpp"))

;; ============================================================================
;; Tensors with autograd, on native BLAS. Roadmap step 3: lift jabla.autograd
;; from scalars to arrays. Validators: one attention block matches PyTorch
;; element-wise; end-to-end, nanoGPT's loss-per-step curve on TinyShakespeare
;; (log to experiments/). References: reference/llm.c, reference/nanoGPT.
;;
;; Step 2 (blas/sgemm) has landed, so matmul has a native kernel to call.
;; SCAFFOLD ONLY -- the op forwards and the tensor-level backward are the work.
;; ============================================================================

;; --- Representation (decided) -----------------------------------------------
;; A tensor is a jank map: {:shape [d0 d1 ...] :dtype :f32 :id <handle>}.
;;   - :shape -- dimension sizes (row-major), a plain jank vector.
;;   - :dtype -- :f32 in the buffer (matches sgemm and the GPU end-state); the
;;     jank API speaks doubles and narrows at the boundary. Carrying :dtype keeps
;;     fp16/bf16 a storage change later, not a rewrite.
;;   - :id    -- index into a native float32 buffer C++ owns (tensor.hpp's
;;     registry), the same ownership model as blas/sgemm. Bulk data never lives in
;;     jank: it holds only the handle and marshals at the edges (->tensor /
;;     ->vectors). We went native from the start rather than via a flat-doubles
;;     shortcut, since blas/sgemm already proved the interop path.

;; --- Autograd (the core design task) ----------------------------------------
;; Reuse jabla.autograd's tape, generalized: a node carries a *tensor* payload and
;; a local vjp (vector-Jacobian product) instead of a scalar partial. Each op
;; records {forward-tensor, input-ids, vjp}; backward is the same reverse scan,
;; but each step pushes a tensor gradient into its inputs and accumulates.
;;   Key insight: matmul's vjp is itself two matmuls of the upstream gradient with
;;   the inputs (work out which sides/transposes) -- so backward *also* routes
;;   through blas/sgemm. Derive the rest the same way you did the scalar ops.
;; See docs/autograd-references.md (the flat-tape / vjp design).

;; --- Public surface ---------------------------------------------------------
;; Construction + readback are done; the ops (matmul/add/backward) are next.
;; NOTE: matmul's forward will (:require [jabla.blas :as blas]) -- add it then.

(defn- shape-of
  "Infer a row-major shape from nested vectors: count siblings at each depth,
  following the first element down until the leaves stop being vectors. Assumes
  rectangular nesting."
  [v]
  (->> v (iterate first) (take-while vector?) (mapv count)))

(defn ->tensor
  "Construct a tensor from nested jank vectors (row-major). Infers :shape, then
  flattens row-major and hands the elements to the C++ registry, which returns
  the buffer handle we store as :id. (vec forces the flatten -- jank marshals a
  persistent vector to std::vector, but not a lazy seq.)"
  [v]
  (let [shape (shape-of v)
        t-id  (cpp/createTensor (-> v flatten vec))]
    {:shape shape
     :dtype :f32
     :id    t-id}))

(defn get-shape
  "Vector of dimension sizes."
  [t]
  (:shape t))

(defn get-dtype
  "Element type keyword (:f32 to start)."
  [t]
  (:dtype t))

(defn reshape
  "Nest a row-major element sequence into vectors of `shape`.

  Tracks clojure.core.matrix/reshape: flattens `m` first (its current shape is
  irrelevant), then refills row-major -- truncating if there are too many
  elements, zero-padding if too few.

  Built outside-in: `build` peels the outermost dim off `dims`, emits one child
  per index, and recurses on the rest; the base case (no dims left) is a single
  element. `stride` is the row-major stride of the current axis -- how many flat
  elements one step along it spans. Eager vector ops only: jank's lazy
  partition/rseq are unreliable (docs/jank-notes.md)."
  [m shape]
  (let [flat (vec (flatten m))
        n    (count flat)]
    (letfn [(build [offset dims]
              (if (empty? dims)
                ;; one element; zero-pad once we run off the end of `flat`
                (if (< offset n) (nth flat offset) 0.0)
                (let [stride (reduce * 1 (rest dims))]
                  (mapv (fn [i] (build (+ offset (* i stride)) (rest dims)))
                        (range (first dims))))))]
      (build 0 shape))))

(defn ->vectors
  "Read a tensor back into nested jank vectors (for tests / debugging): pull the
  flat buffer from C++ by :id, then reshape it to the tensor's shape. This is
  core.matrix's to-nested-vectors -- the inverse of ->tensor."
  [t]
  (let [raw-v (-> t :id cpp/getTensor)]
    (reshape raw-v (get-shape t))))

;; --- Ops: start with matmul + add; the rest follow the same forward+vjp shape --

(defn matmul
  "a (m x k) . b (k x n) -> (m x n). Forward routes through blas/sgemm; records a
  node whose vjp is two matmuls of the upstream gradient with a and b."
  [_a _b]
  (throw (ex-info "not implemented -- forward via blas/sgemm" {})))

(defn add
  "Elementwise add (with broadcasting). vjp passes the gradient through (mind the
  broadcast axes: sum the gradient back down to each input's shape)."
  [_a _b]
  (throw (ex-info "not implemented" {})))

;; TODO(you): the GPT op set, each = forward + vjp, validated vs PyTorch:
;;   mul, relu/gelu, softmax, layernorm, embedding lookup, cross-entropy.

;; --- Backward ----------------------------------------------------------------

(defn backward!
  "Seed the root gradient (ones), reverse-scan the tape, accumulate tensor
  gradients into each node's inputs (same structure as jabla.autograd/backward!)."
  [_root]
  (throw (ex-info "not implemented" {})))

(defn grad
  "Accumulated gradient tensor for a leaf (after backward!)."
  [_t]
  (throw (ex-info "not implemented" {})))

;; --- Milestones (suggested order) -------------------------------------------
;; 1. [done] ->tensor / get-shape / get-dtype / reshape / ->vectors on the
;;    native C++ registry (tensor.hpp).
;; 2. matmul forward via blas/sgemm; check vs blas/matmul-reference.
;; 3. add forward + tape recording for both ops.
;; 4. backward! for matmul + add; gradient-check via finite differences (reuse
;;    the grad-check idea from test/jabla/autograd_test.jank) before trusting it.
;; 5. then the rest of the op set, building toward one attention block vs PyTorch.
