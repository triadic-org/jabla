#!/usr/bin/env bash
# jabla pre-commit hook. Install with: make hooks
# Bypass once with: git commit --no-verify
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "[pre-commit] ASCII check (jank lexer rejects non-ASCII)..."
make -s lint-ascii

echo "[pre-commit] clj-kondo lint..."
make -s lint

echo "[pre-commit] ok"
