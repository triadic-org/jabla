(ns jabla.test-runner
  (:require [clojure.test :as test]
            [jabla.autograd-test]
            [jabla.tensor-test]
            [jabla.schema-test]
            [jabla.jalli-test]))

;; Runs the suites via clojure.test. Invoked by `make test` ->
;; jank ... run-main jabla.test-runner [suite].
;;   no arg          -> run all suites
;;   <suite-name>    -> run just that one (e.g. `make test SUITE=autograd`)

(def ^:private suites
  {"autograd" 'jabla.autograd-test
   "tensor"   'jabla.tensor-test
   "schema"   'jabla.schema-test
   "jalli"    'jabla.jalli-test})

(defn -main [& args]
  (let [names     (filter seq args)                        ; ignore blank/""
        namespaces (if (seq names) (keep suites names) (vals suites))
        summary    (apply test/run-tests namespaces)
        ok?        (and (zero? (:fail summary)) (zero? (:error summary)))]
    (println (if ok? "RESULT: PASS" "RESULT: FAIL"))
    ;; Fail the process on failures/errors so `make test` exits non-zero (CI).
    ;; jank exits 1 on an uncaught throw; there's no System/exit equivalent yet.
    (when-not ok?
      (throw (ex-info "tests failed" (select-keys summary [:fail :error]))))))
