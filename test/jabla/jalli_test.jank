(ns jabla.jalli-test
  (:require [clojure.test :refer [deftest is testing]]
            [jabla.jalli :as jalli]))

;; Tests for the schema-as-data validation layer (jabla.jalli). Doubles as
;; executable documentation of the schema grammar: a leaf (:tensor), a composite
;; (:and), and a dependent-shape op-boundary schema (:matmul over a 2-tuple).

(def t23 {:shape [2 3] :dtype :f32 :id 0 :op :leaf :inputs []})   ; 2x3 tensor
(def t34 {:shape [3 4] :dtype :f32 :id 1 :op :leaf :inputs []})   ; 3x4 tensor
(def t24 {:shape [2 4] :dtype :f32 :id 2 :op :leaf :inputs []})   ; 2x4 tensor
(def bad-dtype (assoc t23 :dtype :f64))

(deftest leaf-tensor
  (testing ":tensor leaf -- bare keyword and [:tensor] vector both validate"
    (is (jalli/validate :tensor t23))
    (is (jalli/validate [:tensor] t23))
    (is (nil? (jalli/explain :tensor t23))))
  (testing "a malformed tensor fails, and explain names the problem"
    (is (not (jalli/validate :tensor bad-dtype)))
    (is (seq (jalli/explain :tensor bad-dtype)))))

(deftest composite-and
  (testing ":and -- value must satisfy every child schema"
    (is (jalli/validate [:and :tensor] t23))
    (is (not (jalli/validate [:and :tensor] bad-dtype)))))

(deftest matmul-boundary
  (testing ":matmul -- a 2-tuple [a b] of tensors with matching inner dims"
    (is (jalli/validate [:matmul] [t23 t34]))          ; 2x3 . 3x4 -> ok
    (is (nil? (jalli/explain [:matmul] [t23 t34]))))
  (testing ":matmul rejects incompatible shapes (the segfault-prevention case)"
    (is (not (jalli/validate [:matmul] [t23 t24])))    ; 2x3 . 2x4 -> 3 != 2
    (is (seq (jalli/explain [:matmul] [t23 t24]))))
  (testing ":matmul rejects a non-tensor operand and a bad arity"
    (is (not (jalli/validate [:matmul] [t23 42])))
    (is (not (jalli/validate [:matmul] [t23])))))

(deftest same-shape-boundary
  (testing ":same-shape -- a 2-tuple [a b] of tensors with equal shapes (add/mul)"
    (is (jalli/validate [:same-shape] [t23 (assoc t23 :id 9)]))   ; both 2x3 -> ok
    (is (nil? (jalli/explain [:same-shape] [t23 (assoc t23 :id 9)]))))
  (testing ":same-shape rejects differing shapes and non-tensors"
    (is (not (jalli/validate [:same-shape] [t23 t34])))           ; 2x3 vs 3x4
    (is (seq (jalli/explain [:same-shape] [t23 t34])))
    (is (not (jalli/validate [:same-shape] [t23 42])))))

(deftest check-and-humanize
  (testing "check returns a valid value unchanged"
    (is (= t23 (jalli/check :tensor t23))))
  (testing "humanize joins an explain result into one string"
    (is (string? (jalli/humanize (jalli/explain :tensor bad-dtype))))
    (is (nil? (jalli/humanize nil)))))

(deftest tuple-positional
  (testing ":tuple -- positional, i-th element matches i-th child schema"
    (is (jalli/validate [:tuple :tensor] [t23]))               ; unary arg-vector
    (is (jalli/validate [:tuple :tensor :tensor] [t23 t34])))  ; binary arg-vector
  (testing ":tuple rejects wrong arity and a bad element"
    (is (not (jalli/validate [:tuple :tensor] [t23 t34])))     ; arity 1 != 2
    (is (not (jalli/validate [:tuple :tensor] [bad-dtype])))))

;; --- defn-checked: the contract rides on the definition ----------------------
;; identity-tensor returns its arg (a valid tensor); strip-op returns a non-tensor,
;; to exercise the :ret check independently of the :args check.
(jalli/defn-checked identity-tensor
  "Returns its tensor arg unchanged."
  {:args [:tuple :tensor] :ret :tensor}
  [t]
  t)

(jalli/defn-checked strip-op
  "Drops :op, so the return is NOT a well-formed tensor."
  {:ret :tensor}
  [t]
  (dissoc t :op))

(deftest defn-checked-contract
  (testing "valid args + valid return pass straight through"
    (is (= t23 (identity-tensor t23))))
  (testing "a bad argument throws (before the body)"
    (is (thrown? :default (identity-tensor bad-dtype))))
  (testing "a bad return throws (after the body)"
    (is (thrown? :default (strip-op t23)))))
