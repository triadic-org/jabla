(ns jabla.test-util
  (:require [jabla.autograd :as ag]
            [jabla.tensor :as tt]))

;; Domain test helpers (clojure.test is the framework; this is jabla-specific
;; assertions + oracles, used inside clojure.test's `is`).

(defn approx?
  "True when |expected - actual| <= tol. clojure.test has no float-tolerance
  assertion, so use as (is (approx? expected actual tol))."
  [expected actual tol]
  (<= (abs (- (double expected) (double actual))) (double tol)))

(defn grad-check
  "Numerical gradient check: backward!'s analytic gradient vs a central finite
  difference, for any expression. `build` takes a vector of values and returns the
  output value; `inputs` is the vector of input scalars. Returns true iff every
  input's analytic grad matches its finite difference within a relative+absolute
  tolerance. Use as (is (grad-check build inputs))."
  [build inputs]
  (ag/reset-tape!)
  (let [input-values    (mapv ag/push-leaf! inputs)
        output          (build input-values)
        _               (ag/backward! output)
        analytic-grads  (mapv ag/get-grad input-values)
        h               1e-6
        output-at       (fn [scalars] (ag/reset-tape!) (ag/get-data (build (mapv ag/push-leaf! scalars))))
        numerical-grads (vec (map-indexed
                             (fn [index _]
                               (let [bumped (fn [delta]
                                              (output-at (assoc inputs index (+ (nth inputs index) delta))))]
                                 (/ (- (bumped h) (bumped (- h))) (* 2.0 h))))
                             inputs))]
    (every? (fn [[analytic numerical]]
              (<= (abs (- analytic numerical)) (+ 1e-6 (* 1e-4 (abs analytic)))))
            (map vector analytic-grads numerical-grads))))

(defn matmul-reference
  "Naive row-by-column matrix multiply, pure jank -- the ground-truth oracle to
  diff the native jabla.tensor/matmul against. a is m x k, b is k x n -> m x n.
  (Was the target of the retired blas/sgemm spike; now lives here as a test
  oracle since the spike's job is done.)"
  [a b]
  (let [m (count a)
        k (count (first a))
        n (count (first b))]
    (vec (for [i (range m)]
           (vec (for [j (range n)]
                  (reduce + 0.0
                          (for [p (range k)]
                            (* (nth (nth a i) p)
                               (nth (nth b p) j))))))))))

;; --- Tensor engine (node-on-tensor DAG) helpers -----------------------------

(defn transpose-of
  "Pure-jank 2-D transpose oracle (rows <-> cols): a is m x n nested vectors -> n x m.
  Ground truth for the matmul vjp test (dA = dY . Bt, dB = At . dY) -- independent of
  how tensor.jank computes transposes (a transpose op vs sgemm's CblasTrans flag)."
  [a]
  (let [m (count a)
        n (count (first a))]
    (vec (for [j (range n)]
           (vec (for [i (range m)]
                  (nth (nth a i) j)))))))

(defn tensor-sum
  "Sum of every element of a tensor -- the scalar objective the tensor grad-check
  differentiates, so an input element's analytic grad should equal d(sum out)/d(elt)."
  [t]
  (reduce + 0.0 (vec (flatten (tt/->vectors t)))))

(defn- rebuild-inputs
  "Reconstruct the input tensors from flat data + shapes, with input `i`'s flat
  element `j` bumped by `delta` (all others unchanged). Fresh tensors each call --
  a node-on-tensor forward is pure (no global tape), so perturbations need no reset
  between them, unlike the scalar grad-check."
  [flats shapes i j delta]
  (mapv (fn [k]
          (let [xs (nth flats k)
                xs (if (= k i) (assoc xs j (+ (nth xs j) delta)) xs)]
            (tt/->tensor (tt/reshape xs (nth shapes k)))))
        (range (count flats))))

(defn tensor-grad-check
  "Tensor analogue of grad-check for the stage-1 engine. `build` takes a vector of
  input tensors and returns the output tensor; `inputs` is a vector of nested-vector
  input data. Objective is sum(output): each input element's analytic gradient must
  match the central finite difference of sum(build inputs), within an f32-appropriate
  tolerance. Use as (is (tensor-grad-check build inputs)).

  Assumes the stage-1 API: (backward! root) returns the grads and (grad grads t)
  reads one out -- adjust those two calls if your signatures differ. f32 buffers
  force a looser h/tol than the scalar (f64) check; both forwards so far are linear,
  so central differences are roundoff-exact regardless of h."
  [build inputs]
  (let [in-tensors (mapv tt/->tensor inputs)
        output     (build in-tensors)
        grads      (tt/backward! output)
        analytic   (mapv (fn [t] (vec (flatten (tt/->vectors (tt/grad grads t))))) in-tensors)
        shapes     (mapv tt/get-shape in-tensors)
        flats      (mapv (fn [v] (vec (flatten v))) inputs)
        h          1e-2
        sum-at     (fn [i j delta] (tensor-sum (build (rebuild-inputs flats shapes i j delta))))
        match?     (fn [a n] (<= (abs (- a n)) (+ 1e-2 (* 1e-2 (abs a)))))
        results    (vec (for [i (range (count inputs))
                              j (range (count (nth flats i)))]
                          (let [numerical (/ (- (sum-at i j h) (sum-at i j (- h))) (* 2.0 h))]
                            (match? (nth (nth analytic i) j) numerical))))]
    (every? true? results)))
