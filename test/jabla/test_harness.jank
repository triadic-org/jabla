(ns jabla.test-harness)

;; Hand-rolled test harness. jank has no test framework yet, so this is the
;; substitute. It tracks pass/fail/pending counts, names each failing test, and
;; supports a before-each setup hook so tests don't repeat their fixtures.
;;
;; Usage (see jabla.autograd-test):
;;   (before-each! ag/reset-tape!)   ; runs before every deftest
;;   (deftest "x + x"
;;     (approx= 6.0 (some-value) 1e-9))
;;   (summary!)  ; prints which tests failed + totals; returns true iff all passed

(def ^:private initial-state
  {:pass 0 :fail 0 :pending 0 :failures [] :failed-tests #{}
   :current nil :before-each nil})

(def ^:private state (atom initial-state))

(defn clear! [] (reset! state initial-state))

(defn before-each!
  "Register a thunk to run before each deftest body (e.g. reset shared state).
  Scoped per suite: set it at the top of your test ns's run fn; clear! removes it."
  [thunk]
  (swap! state assoc :before-each thunk))

;; -- internals the deftest macro calls (public so they resolve in test nses) --
(defn set-current-test! [test-name] (swap! state assoc :current test-name))
(defn run-before-each! [] (when-let [thunk (:before-each @state)] (thunk)))

(defn- record! [ok? message]
  (if ok?
    (swap! state update :pass inc)
    (let [test-name (:current @state)]
      (swap! state #(-> %
                        (update :fail inc)
                        (update :failures conj (str test-name ": " message))
                        (update :failed-tests conj test-name)))
      (println "  FAIL:" message))))

(defn check
  "Core assertion. ok? is a boolean; message describes the case."
  [ok? message]
  (record! ok? message)
  ok?)

(defn is=
  "Assert (= expected actual)."
  [expected actual]
  (check (= expected actual)
         (str "expected " (pr-str expected) " got " (pr-str actual))))

(defn approx=
  "Assert |expected - actual| <= tol. For floats vs PyTorch/Python ground truth."
  [expected actual tol]
  (check (<= (abs (- (double expected) (double actual))) (double tol))
         (str "expected ~" expected " (+/-" tol ") got " actual)))

(defn pending
  "Mark a test (or branch) as not-yet-implemented. Counts separately; never fails."
  [message]
  (swap! state update :pending inc)
  (println "  PENDING:" message))

(defmacro deftest
  "Run a named test: print its name, run the before-each hook, then the body."
  [test-name & body]
  `(do (println "TEST:" ~test-name)
       (jabla.test-harness/set-current-test! ~test-name)
       (jabla.test-harness/run-before-each!)
       ~@body))

(defn summary!
  "Print which tests failed plus pass/fail/pending totals. Returns true iff there
  were no failures (pending does not count as a failure)."
  []
  (let [{:keys [pass fail pending failed-tests]} @state]
    (when (seq failed-tests)
      (println "\nFailed:")
      (doseq [test-name failed-tests]
        (println "  -" test-name)))
    (println (str "\n=== " pass " passed, " fail " failed, " pending " pending ==="))
    (zero? fail)))
